# Firebase client (public — safe for NEXT_PUBLIC_*, still do not commit real .env.local)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Administrator UID (must match the Firebase Auth user used to sign in at /admin/contacts)
# Set BOTH to the SAME Firebase Auth uid in Vercel Production (no quotes).
# Client gate uses NEXT_PUBLIC_ADMIN_UID; API auth accepts either after normalization.
NEXT_PUBLIC_ADMIN_UID=
ADMIN_UID=

# Firebase Admin service account JSON for server APIs (/api/contact, /api/admin/*, /api/trace)
# Paste as a single-line JSON string, or base64 of that JSON.
# Never commit the real value. Never put this in GitHub.
FIREBASE_SERVICE_ACCOUNT_JSON=

# Optional: protect POST /api/cron/cleanup-traces (Vercel Cron alternative to Cloud Functions)
CRON_SECRET=

# Canonical site URL for sitemap.xml / robots.txt
NEXT_PUBLIC_SITE_URL=https://miav-922228.com

# Firebase Console checklist for Trace Map:
# - Enable Anonymous Authentication
# - Enable Google Sign-in
# - Authorized domains include miav-922228.com
